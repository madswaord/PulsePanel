# PulsePanel 后端监听端口（Docker 默认映射 8710:8710）
PORT=8710
TIMEZONE=Asia/Shanghai

# OPNsense 连接配置
# 示例：OPNSENSE_BASE_URL=https://192.168.10.1
OPNSENSE_BASE_URL=https://192.168.10.1
OPNSENSE_API_KEY=replace_me
OPNSENSE_API_SECRET=replace_me

# 自签证书 / 内网环境一般可先设为 false，公网正式环境建议 true
VERIFY_TLS=false
OPNSENSE_TIMEOUT_MS=10000

# 可选增强来源（当前主要保留扩展位）
TRAFFIC_PROVIDER=core
ENABLE_CADDY_LOGS=false
ENABLE_DNS_LOGS=false
CADDY_ACCESS_LOG_PATH=
DNS_LOG_PATH=
